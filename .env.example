# Root Environment Variables (shared between services)

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_tutor
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_REFRESH_SECRET_KEY=your-refresh-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Password Reset
PASSWORD_RESET_SECRET=your-password-reset-secret-min-32-chars
PASSWORD_RESET_EXPIRATION_MINUTES=30

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@finance-tutor.app

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Application
ENVIRONMENT=development
DEBUG=true
RATE_LIMIT_PER_MINUTE=100

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend (Next.js - must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_NAME=Finance Tutor
